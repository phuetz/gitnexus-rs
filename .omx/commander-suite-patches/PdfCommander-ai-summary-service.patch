@@ -0,0 +1,145 @@
+using FluentAssertions;
+using Microsoft.Extensions.Logging.Abstractions;
+using Moq;
+using PdfCommander.Core.Models;
+using PdfCommander.Core.Services.AI;
+using PdfCommander.Core.Services.Text;
+using PdfSharpCore.Pdf;
+using Xunit;
+
+namespace PdfCommander.Tests;
+
+public class AiSummaryServiceTests : IDisposable
+{
+    private readonly string _tempDir;
+
+    public AiSummaryServiceTests()
+    {
+        _tempDir = Path.Combine(Path.GetTempPath(), $"PdfCommanderSummary_{Guid.NewGuid():N}");
+        Directory.CreateDirectory(_tempDir);
+    }
+
+    public void Dispose()
+    {
+        try
+        {
+            Directory.Delete(_tempDir, recursive: true);
+        }
+        catch
+        {
+        }
+    }
+
+    [Fact]
+    public async Task SummarizeTextAsync_UsesAiAndReturnsOneParagraph()
+    {
+        var ai = CreateAiService("First line.\nSecond line.");
+        var textExtraction = new Mock<ITextExtractionService>();
+        var service = CreateService(ai.Object, textExtraction.Object);
+
+        var result = await service.SummarizeTextAsync("Source document text.", pageCount: 1);
+
+        result.IsSuccess.Should().BeTrue();
+        result.Summary.Should().Be("First line. Second line.");
+        result.PageCount.Should().Be(1);
+        result.Provider.Should().Be("test");
+        result.WordCount.Should().Be(4);
+        ai.Verify(x => x.AskAsync(
+            It.Is<string>(context => context.Contains("Source document text.")),
+            It.Is<string>(question => question.Contains("un seul paragraphe")),
+            It.IsAny<CancellationToken>()), Times.Once);
+    }
+
+    [Fact]
+    public async Task SummarizePdfAsync_ExtractsAllPagesBeforeCallingAi()
+    {
+        var pdfPath = CreatePdf(pageCount: 2);
+        var ai = CreateAiService("Combined summary.");
+        var textExtraction = CreateTextExtraction("First page text.", "Second page text.");
+        var service = CreateService(ai.Object, textExtraction.Object);
+
+        var result = await service.SummarizePdfAsync(pdfPath);
+
+        result.IsSuccess.Should().BeTrue();
+        result.PageCount.Should().Be(2);
+        result.Summary.Should().Be("Combined summary.");
+        ai.Verify(x => x.AskAsync(
+            It.Is<string>(context =>
+                context.Contains("First page text.") &&
+                context.Contains("Second page text.")),
+            It.IsAny<string>(),
+            It.IsAny<CancellationToken>()), Times.Once);
+        textExtraction.Verify(x => x.ExtractPageTextAsync(pdfPath, 0, It.IsAny<CancellationToken>()), Times.Once);
+        textExtraction.Verify(x => x.ExtractPageTextAsync(pdfPath, 1, It.IsAny<CancellationToken>()), Times.Once);
+    }
+
+    [Fact]
+    public async Task SummarizePdfAsync_WhenNoExtractableText_ReturnsFailureWithoutCallingAi()
+    {
+        var pdfPath = CreatePdf(pageCount: 1);
+        var ai = CreateAiService("Should not be used.");
+        var textExtraction = CreateTextExtraction("");
+        var service = CreateService(ai.Object, textExtraction.Object);
+
+        var result = await service.SummarizePdfAsync(pdfPath);
+
+        result.IsSuccess.Should().BeFalse();
+        result.Summary.Should().BeEmpty();
+        result.Error.Should().Contain("Aucun texte");
+        ai.Verify(x => x.AskAsync(
+            It.IsAny<string>(),
+            It.IsAny<string>(),
+            It.IsAny<CancellationToken>()), Times.Never);
+    }
+
+    private AiSummaryService CreateService(IAiService ai, ITextExtractionService textExtraction)
+    {
+        return new AiSummaryService(ai, textExtraction, NullLogger<AiSummaryService>.Instance);
+    }
+
+    private static Mock<IAiService> CreateAiService(string responseText)
+    {
+        var ai = new Mock<IAiService>();
+        ai.Setup(x => x.AskAsync(
+                It.IsAny<string>(),
+                It.IsAny<string>(),
+                It.IsAny<CancellationToken>()))
+            .ReturnsAsync(new AiResponse
+            {
+                Text = responseText,
+                IsSuccess = true,
+                Provider = "test",
+                Duration = TimeSpan.FromMilliseconds(1)
+            });
+
+        return ai;
+    }
+
+    private static Mock<ITextExtractionService> CreateTextExtraction(params string[] pageTexts)
+    {
+        var textExtraction = new Mock<ITextExtractionService>();
+        textExtraction.Setup(x => x.ExtractPageTextAsync(
+                It.IsAny<string>(),
+                It.IsAny<int>(),
+                It.IsAny<CancellationToken>()))
+            .Returns((string _, int pageIndex, CancellationToken _) =>
+                Task.FromResult(pageIndex >= 0 && pageIndex < pageTexts.Length ? pageTexts[pageIndex] : ""));
+
+        textExtraction.Setup(x => x.ExtractTextWithPositionsAsync(
+                It.IsAny<string>(),
+                It.IsAny<int>(),
+                It.IsAny<CancellationToken>()))
+            .ReturnsAsync(new List<PdfTextBlock>());
+
+        return textExtraction;
+    }
+
+    private string CreatePdf(int pageCount)
+    {
+        var path = Path.Combine(_tempDir, $"{Guid.NewGuid():N}.pdf");
+        using var document = new PdfDocument();
+
+        for (var i = 0; i < pageCount; i++)
+        {
+            document.AddPage();
+        }
+
+        document.Save(path);
+        return path;
+    }
+}
