--- /dev/null
+++ b/src/PdfCommander.Core/Services/AI/AiSummaryService.cs
@@ -0,0 +1,130 @@
+using System.Text;
+using Microsoft.Extensions.Logging;
+using PdfCommander.Core.Services.Text;
+using PdfSharpCore.Pdf.IO;
+
+namespace PdfCommander.Core.Services.AI;
+
+public class AiSummaryService : IAiSummaryService
+{
+    private const int MaxPagesToExtract = 30;
+    private const int MaxContextCharacters = 12000;
+
+    private readonly IAiService _ai;
+    private readonly ITextExtractionService _textExtraction;
+    private readonly ILogger<AiSummaryService> _logger;
+
+    public AiSummaryService(
+        IAiService ai,
+        ITextExtractionService textExtraction,
+        ILogger<AiSummaryService> logger)
+    {
+        _ai = ai;
+        _textExtraction = textExtraction;
+        _logger = logger;
+    }
+
+    public async Task<AiSummaryResult> SummarizePdfAsync(string pdfPath, CancellationToken ct = default)
+    {
+        if (string.IsNullOrWhiteSpace(pdfPath))
+            throw new ArgumentException("A PDF path is required.", nameof(pdfPath));
+
+        if (!File.Exists(pdfPath))
+            throw new FileNotFoundException("PDF file not found.", pdfPath);
+
+        var extracted = await ExtractPdfTextAsync(pdfPath, ct);
+        return await SummarizeTextAsync(extracted.Text, extracted.PageCount, ct);
+    }
+
+    public async Task<AiSummaryResult> SummarizeTextAsync(string text, int pageCount = 0, CancellationToken ct = default)
+    {
+        if (string.IsNullOrWhiteSpace(text))
+        {
+            return new AiSummaryResult(
+                "",
+                pageCount,
+                0,
+                "",
+                false,
+                "Aucun texte extractible pour generer un resume.");
+        }
+
+        var context = Truncate(text, MaxContextCharacters);
+        const string question =
+            "Redige un resume du document en un seul paragraphe clair, sans liste a puces, en 120 mots maximum.";
+
+        var response = await _ai.AskAsync(context, question, ct);
+        if (!response.IsSuccess)
+        {
+            return new AiSummaryResult(
+                "",
+                pageCount,
+                0,
+                response.Provider,
+                false,
+                response.Error);
+        }
+
+        var summary = NormalizeOneParagraph(response.Text);
+        return new AiSummaryResult(
+            summary,
+            pageCount,
+            CountWords(summary),
+            response.Provider,
+            true,
+            null);
+    }
+
+    private async Task<(string Text, int PageCount)> ExtractPdfTextAsync(string pdfPath, CancellationToken ct)
+    {
+        using var doc = PdfReader.Open(pdfPath, PdfDocumentOpenMode.ReadOnly);
+        var pageCount = doc.PageCount;
+        var maxPages = Math.Min(pageCount, MaxPagesToExtract);
+        var builder = new StringBuilder();
+
+        for (var pageIndex = 0; pageIndex < maxPages; pageIndex++)
+        {
+            ct.ThrowIfCancellationRequested();
+
+            try
+            {
+                var pageText = await ExtractPageTextAsync(pdfPath, pageIndex, ct);
+                if (!string.IsNullOrWhiteSpace(pageText))
+                    builder.AppendLine(pageText);
+            }
+            catch (OperationCanceledException)
+            {
+                throw;
+            }
+            catch (Exception ex)
+            {
+                _logger.LogWarning(ex, "Failed to extract text from page {PageIndex} of {PdfPath}", pageIndex, pdfPath);
+            }
+        }
+
+        return (builder.ToString(), pageCount);
+    }
+
+    private async Task<string> ExtractPageTextAsync(string pdfPath, int pageIndex, CancellationToken ct)
+    {
+        var pageText = await _textExtraction.ExtractPageTextAsync(pdfPath, pageIndex, ct);
+        if (!string.IsNullOrWhiteSpace(pageText))
+            return pageText;
+
+        var blocks = await _textExtraction.ExtractTextWithPositionsAsync(pdfPath, pageIndex, ct);
+        return string.Join(" ", blocks.Select(block => block.Text));
+    }
+
+    private static string Truncate(string text, int maxCharacters)
+    {
+        return text.Length <= maxCharacters
+            ? text
+            : text[..maxCharacters];
+    }
+
+    private static string NormalizeOneParagraph(string text)
+    {
+        return string.Join(
+            " ",
+            text.Split([' ', '\t', '\r', '\n'], StringSplitOptions.RemoveEmptyEntries));
+    }
+
+    private static int CountWords(string text)
+    {
+        return text.Split([' ', '\t', '\r', '\n'], StringSplitOptions.RemoveEmptyEntries).Length;
+    }
+}
