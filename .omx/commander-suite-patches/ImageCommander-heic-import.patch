+    public static bool IsHeifExtension(string filePath)
+    {
+        var ext = Path.GetExtension(filePath).ToLowerInvariant();
+        return ext is ".heic" or ".heif" or ".hif";
+    }
+
+    private ImageDocument ImportHeif(string filePath)
+    {
+        try
+        {
+            using var context = new HeifContext(filePath);
+            using var handle = context.GetPrimaryImageHandle();
+            ValidateDimensions(handle.Width, handle.Height);
+
+            var decodeOptions = new HeifDecodingOptions
+            {
+                ConvertHdrToEightBit = true
+            };
+            using var image = handle.Decode(HeifColorspace.Rgb, HeifChroma.InterleavedRgba32, decodeOptions);
+            using var bitmap = CopyHeifImageToBitmap(image);
+            var sourceFormat = new SourceDocumentFormat(
+                InferBitDepthFromChannelBits(handle.BitDepth),
+                InferColorSpace(image.IccColorProfile));
+
+            return CreateDocumentFromBitmap(bitmap, filePath, sourceFormat);
+        }
+        catch (Exception ex) when (ex is DllNotFoundException or BadImageFormatException or EntryPointNotFoundException)
+        {
+            throw new InvalidOperationException(
+                "Le support HEIC/HEIF necessite la bibliotheque native libheif disponible dans le PATH.",
+                ex);
+        }
+        catch (HeifException ex)
+        {
+            throw new InvalidOperationException($"Impossible de charger le fichier HEIC/HEIF : {filePath}", ex);
+        }
+    }
+
+    private static unsafe SKBitmap CopyHeifImageToBitmap(HeifImage image)
+    {
+        var plane = image.GetPlane(HeifChannel.Interleaved);
+        var bitmap = new SKBitmap(image.Width, image.Height, SKColorType.Rgba8888, SKAlphaType.Premul);
+
+        var sourceBase = (byte*)plane.Scan0.ToPointer();
+        var destinationBase = (byte*)bitmap.GetPixels().ToPointer();
+
+        for (var y = 0; y < image.Height; y++)
+        {
+            var sourceRow = sourceBase + y * plane.Stride;
+            var destinationRow = destinationBase + y * bitmap.RowBytes;
+
+            for (var x = 0; x < image.Width; x++)
+            {
+                var sourcePixel = sourceRow + x * 4;
+                var destinationPixel = destinationRow + x * 4;
+                var alpha = sourcePixel[3];
+
+                if (image.IsPremultipliedAlpha || alpha == byte.MaxValue)
+                {
+                    destinationPixel[0] = sourcePixel[0];
+                    destinationPixel[1] = sourcePixel[1];
+                    destinationPixel[2] = sourcePixel[2];
+                }
+                else
+                {
+                    destinationPixel[0] = (byte)((sourcePixel[0] * alpha + 127) / 255);
+                    destinationPixel[1] = (byte)((sourcePixel[1] * alpha + 127) / 255);
+                    destinationPixel[2] = (byte)((sourcePixel[2] * alpha + 127) / 255);
+                }
+
+                destinationPixel[3] = alpha;
+            }
+        }
+
+        return bitmap;
+    }
