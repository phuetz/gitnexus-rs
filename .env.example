# Backend gitnexus-mcp HTTP transport
# Démarrer côté gitnexus-rs : `gitnexus serve` (port 3000 par défaut)
# ou `gitnexus serve --port 8080` puis ajuste l'URL ici.
VITE_MCP_URL=http://localhost:3000

# Optionnel — token d'auth si GITNEXUS_HTTP_TOKEN est défini côté serveur
# VITE_MCP_TOKEN=your-token-here
