+    private ImageDocument? LoadBatchDocument(string inputPath)
+    {
+        if (FileService.IsHeifExtension(inputPath))
+            return _fileService.ImportImage(inputPath);
+
+        using var bitmap = SKBitmap.Decode(inputPath);
+        if (bitmap is null)
+            return null;
+
+        var doc = new ImageDocument(bitmap.Width, bitmap.Height, Path.GetFileNameWithoutExtension(inputPath));
+        var layer = doc.AddPixelLayer("Background");
+        using (var canvas = layer.CreateCanvas())
+        {
+            canvas.DrawBitmap(bitmap, 0, 0);
+        }
+
+        return doc;
+    }
