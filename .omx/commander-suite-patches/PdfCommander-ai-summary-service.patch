+namespace PdfCommander.Core.Services.AI;
+
+public record AiSummaryResult(string Summary, int PageCount, int WordCount, string Provider, bool IsSuccess, string? Error);
+
+public interface IAiSummaryService
+{
+    Task<AiSummaryResult> SummarizePdfAsync(string pdfPath, CancellationToken ct = default);
+    Task<AiSummaryResult> SummarizeTextAsync(string text, int pageCount = 0, CancellationToken ct = default);
+}
